# ---- OmniPilot AI environment variables ----
# Copy this file to ".env" and fill in your values.

# LLM provider keys
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Calendar integration (Phase 2 - Cal.com)
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_API_BASE=https://api.cal.com/v2
CALCOM_EVENT_SLUGS=15min,30min
CALCOM_ATTENDEE_EMAIL=your_email@example.com
CALCOM_ATTENDEE_TIMEZONE=Asia/Kolkata

# Database (matches docker-compose.yml: pgvector on host port 5433)
DATABASE_URL=postgresql+asyncpg://omnipilot:omnipilot_pass@localhost:5433/omnipilot_db
POSTGRES_USER=omnipilot
POSTGRES_PASSWORD=omnipilot_pass
POSTGRES_DB=omnipilot_db

# Ollama embeddings endpoint (local; default port 11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
